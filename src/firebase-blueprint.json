{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "businessName": { "type": "string", "description": "User's business name" },
        "customInstructions": { "type": "string", "description": "Custom instructions for the chatbot" },
        "apiKey": { "type": "string", "description": "Optional custom Gemini API key" },
        "websiteUrl": { "type": "string", "description": "User's business website URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Document": {
      "title": "Document",
      "description": "Uploaded document for chatbot training",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "content": { "type": "string", "description": "Extracted text content from the document" },
        "status": { "type": "string", "enum": ["Processing", "Processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "content"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (expense or income).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["expense", "income"] },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "category", "type", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/documents/{docId}": {
      "schema": "Document",
      "description": "User uploaded documents"
    },
    "/users/{userId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "User chat history"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User financial transactions"
    }
  }
}
